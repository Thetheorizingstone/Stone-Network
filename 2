<!DOCTYPE html>
<html>
<head>
    <style>
        body { background: #05070a; color: #e6edf3; font-family: monospace; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        #output { font-size: 2rem; color: #00ffcc; border: 1px solid #00ffcc; padding: 20px; border-radius: 10px; box-shadow: 0 0 15px rgba(0, 255, 204, 0.2); }
        #timestamp { font-size: 10px; color: #444; margin-top: 10px; }
    </style>
</head>
<body>
    <div id="output">WAITING FOR DATA...</div>
    <div id="timestamp">SYNCING WITH CLOUD</div>

    <script>
        const BUCKET = "6n8m6n8m6n8m";
        const KEY = "stone_network_data";

        async function pullData() {
            try {
                // Cache-buster (?t=) ensures we get the newest data every time
                const res = await fetch(`https://kvdb.io/${BUCKET}/${KEY}?t=${Date.now()}`);
                if (res.ok) {
                    const val = await res.text();
                    document.getElementById("output").innerText = val;
                    document.getElementById("timestamp").innerText = "LAST SYNC: " + new Date().toLocaleTimeString();
                }
            } catch(e) {
                console.log("Searching for signal...");
            }
        }

        // Poll the cloud every 2 seconds for updates
        setInterval(pullData, 2000);
    </script>
</body>
</html>
