<!DOCTYPE html>
<html>
<head>
    <style>
        body { background: #0d1117; color: #58a6ff; font-family: sans-serif; padding: 20px; }
        input { background: #161b22; border: 1px solid #30363d; color: white; padding: 10px; width: 80%; border-radius: 4px; }
        button { background: #238636; color: white; border: none; padding: 10px; margin-top: 10px; cursor: pointer; border-radius: 4px; width: 100%; font-weight: bold; }
        #status { font-size: 10px; color: #8b949e; margin-top: 10px; }
    </style>
</head>
<body>
    <h3>Stone Input</h3>
    <input type="text" id="dataInput" placeholder="Enter command or data...">
    <button onclick="transmit()">SEND TO NETWORK</button>
    <div id="status">Ready</div>

    <script>
        const BUCKET = "6n8m6n8m6n8m"; // Your unique cloud bucket
        const KEY = "stone_network_data";

        async function transmit() {
            const val = document.getElementById("dataInput").value;
            document.getElementById("status").innerText = "Transmitting...";
           
            try {
                await fetch(`https://kvdb.io/${BUCKET}/${KEY}`, {
                    method: 'POST',
                    body: val
                });
                document.getElementById("status").innerText = "Success: Transmitted to Cloud";
                document.getElementById("dataInput").value = ""; // Clear input
            } catch(e) {
                document.getElementById("status").innerText = "Error: Connection Failed";
            }
        }
    </script>
</body>
</html>
